# ============================================================
# OpenCode AI 📊 Telemetry Configuration
# ============================================================

# Enable OpenTelemetry telemetry (true/false)
OPENCODE_ENABLE_TELEMETRY=true

# OTLP endpoint URL (default: OpenTelemetry Collector on localhost:4317)
# Change this if your collector is running elsewhere
OPENCODE_OTLP_ENDPOINT="http://localhost:4317"

# OTLP protocol (grpc or http/json)
OPENCODE_OTLP_PROTOCOL="grpc"

# Resource attributes for OpenTelemetry
# service.name is required, others are optional
OPENCODE_RESOURCE_ATTRIBUTES="service.name=sciloom-pipeline,openinference.project.name=sciloom-pipeline"